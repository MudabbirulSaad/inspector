{
  "$id": "flow-tracer-output.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Flow Tracer output",
  "type": "object",
  "additionalProperties": false,
  "required": ["flows", "insufficientEvidence", "findings"],
  "properties": {
    "flows": {
      "type": "array",
      "maxItems": 3,
      "items": { "$ref": "#/$defs/flow" }
    },
    "insufficientEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "reason", "evidence"],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "evidence.schema.json" }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" }
    }
  },
  "anyOf": [
    { "properties": { "flows": { "type": "array", "minItems": 1 } } },
    {
      "properties": {
        "insufficientEvidence": { "type": "array", "minItems": 1 }
      }
    }
  ],
  "$defs": {
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "action",
        "entryPoint",
        "mainFiles",
        "dataPath",
        "sideEffects",
        "persistencePath",
        "errorPaths",
        "tests",
        "evidence"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "entryPoint": { "$ref": "#/$defs/pathEvidence" },
        "mainFiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileRole" }
        },
        "dataPath": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stepEvidence" }
        },
        "sideEffects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/descriptionEvidence" }
        },
        "persistencePath": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/descriptionEvidence" }
        },
        "errorPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/descriptionEvidence" }
        },
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/descriptionEvidence" }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    },
    "pathEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "evidence"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    },
    "fileRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "evidence"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    },
    "stepEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "evidence"],
      "properties": {
        "step": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    },
    "descriptionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "evidence"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    }
  }
}
