{
  "$id": "run-config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["target", "outputDirectory", "agentRoles", "validationCommands", "verbose"],
  "properties": {
    "target": { "$ref": "repository-target.schema.json" },
    "outputDirectory": { "type": "string", "minLength": 1 },
    "agentRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "architecture",
          "code-quality",
          "security",
          "testing",
          "documentation",
          "qa",
          "knowledge",
          "reporting"
        ]
      },
      "uniqueItems": true
    },
    "validationCommands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verbose": { "type": "boolean" },
    "targetContext": { "type": "string", "minLength": 1 },
    "agents": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "parallelism": { "type": "integer", "minimum": 1 },
    "maxRetries": { "type": "integer", "minimum": 0 },
    "runQualityCommands": { "type": "boolean" },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
