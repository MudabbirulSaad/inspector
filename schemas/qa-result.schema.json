{
  "$id": "qa-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QA Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "qaAgent", "findingId", "status", "rationale", "checks", "requiresFollowUp"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "qaAgent": { "type": "string", "minLength": 1 },
    "findingId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "needs-review"] },
    "rationale": { "type": "string", "minLength": 1 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "needs-review"] },
          "notes": { "type": "string" }
        }
      }
    },
    "requiresFollowUp": { "type": "boolean" },
    "followUpAgent": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
