{
  "$id": "scout-output.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scout output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectType",
    "detectedStack",
    "importantFiles",
    "entryPoints",
    "architectureImpression",
    "openQuestions",
    "findings"
  ],
  "properties": {
    "projectType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "evidence"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    },
    "detectedStack": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "evidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "evidence.schema.json" }
          }
        }
      }
    },
    "importantFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason", "evidence"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "evidence.schema.json" }
          }
        }
      }
    },
    "entryPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "evidence"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "evidence.schema.json" }
          }
        }
      }
    },
    "architectureImpression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "evidence"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "evidence.schema.json" }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" }
    }
  }
}
