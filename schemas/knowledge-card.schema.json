{
  "$id": "knowledge-card.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "topic",
    "summary",
    "sourceRepo",
    "confidence",
    "evidence",
    "tags",
    "audience"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "sourceRepo": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "evidence.schema.json" }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "audience": { "enum": ["coding-agent", "engineer", "maintainer"] },
    "whenToUse": { "type": "string", "minLength": 1 },
    "whenNotToUse": { "type": "string", "minLength": 1 },
    "risks": { "type": "string", "minLength": 1 },
    "adaptationNotes": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
