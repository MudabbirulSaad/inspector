{
  "name": "inspector",
  "version": "0.1.0",
  "description": "CLI for orchestrating Codex-powered codebase inspection swarms.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "validate": "npm test && npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "npm@11.16.0",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^6.0.3"
  }
}
